# Telegram Bot token lấy từ @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABC_your_bot_token_here

# Chat ID cá nhân hoặc group/channel ID
# Sau khi nhắn tin cho bot, chạy: npm run get:chatid
TELEGRAM_CHAT_ID=123456789

# Giờ gửi thông tin đầy đủ (Thời tiết + Vàng + Xăng)
# 8:30 sáng và 6:30 tối mỗi ngày
CRON_TIME=30 8,18 * * *

# Giờ gửi lời chào buổi sáng (6:00 sáng)
CRON_GREETING_MORNING=0 6 * * *

# Giờ gửi lời chào buổi tối (22:30 tối)
CRON_GREETING_NIGHT=30 22 * * *

# Múi giờ Việt Nam
TIMEZONE=Asia/Ho_Chi_Minh

# Tọa độ Huế
LATITUDE=16.4637
LONGITUDE=107.5909

# Tên địa điểm hiển thị trong tin nhắn
LOCATION_NAME=Huế

# Gửi tin nhắn ngay khi start app: true/false
SEND_ON_START=false
